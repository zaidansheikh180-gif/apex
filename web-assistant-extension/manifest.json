{
  "manifest_version": 3,
  "name": "Web AI Assistant",
  "version": "1.0",
  "description": "An AI agent that can browse and interact with the web.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}